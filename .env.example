# Supabase project (Postgres + Storage + Auth) — powers the catalog and the
# /admin panel. See CLAUDE.md for how to get these and the one-time SQL setup.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Contact links used to build order-request messages (cart -> WhatsApp/Telegram)
NEXT_PUBLIC_WHATSAPP_NUMBER=79227373623
NEXT_PUBLIC_TELEGRAM_HANDLE=LysiaSh
NEXT_PUBLIC_CONTACT_EMAIL=lusiae@mail.ru

# Telegram bot that notifies the owner about every new order (see CLAUDE.md).
# Server-only (no NEXT_PUBLIC prefix — the token must never reach the browser).
# Leave empty to disable notifications; orders still work without them.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# DeepL API key, used to machine-translate product title/description into
# EN/FR/ES for non-Russian visitors (see CLAUDE.md). Server-only. Leave
# empty to show the Russian text as-is in every locale.
DEEPL_API_KEY=
